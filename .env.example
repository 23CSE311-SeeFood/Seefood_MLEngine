# Flask service
PORT=5001
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Optional local training/report DB access
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Azure ML online endpoint for /sales/predictions
AZURE_ML_SCORING_URI=https://<endpoint-name>.<region>.inference.ml.azure.com/score
AZURE_ML_API_KEY=<endpoint-primary-key>
# Optional when multiple deployments exist behind one endpoint
AZURE_ML_DEPLOYMENT=blue
